# Copia este fichero como .env y ajusta los valores antes de arrancar en produccion.

PORT=4000
NODE_ENV=development

# Debe ser una cadena aleatoria larga y secreta (por ejemplo: openssl rand -hex 32)
JWT_SECRET=change-this-development-secret-please

# Origen permitido para CORS (URL del frontend)
CLIENT_ORIGIN=http://localhost:5173

# SMTP para el envio de emails de recuperacion de contrasena.
# Si se dejan vacios, el servidor funciona en "modo desarrollo": en lugar de
# enviar el correo, escribe el enlace de recuperacion en la consola del
# servidor y lo expone en la respuesta de la API (solo si NODE_ENV != production).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Task Manager <no-reply@taskmanager.local>"
