<%- include('partials/header', { title: 'Iniciar sesión' }) %>
<div class="auth-card mx-auto">
  <h1 class="h3 mb-3">Bienvenido</h1>
  <p class="text-muted">Accede a tu cuenta para gestionar tus tareas.</p>
  <form action="/login" method="POST" class="mt-4">
    <div class="mb-3">
      <label class="form-label">Email</label>
      <input type="email" name="email" class="form-control" required />
    </div>
    <div class="mb-3">
      <label class="form-label">Contraseña</label>
      <input type="password" name="password" class="form-control" required />
    </div>
    <button class="btn btn-primary w-100">Iniciar sesión</button>
  </form>
  <div class="d-flex justify-content-between mt-3">
    <a href="/forgot">¿Olvidaste tu contraseña?</a>
    <a href="/register">Crear cuenta</a>
  </div>
</div>
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-4XfIbwSvgIHm5MUo1GpT7qIuY4x+fzPCO5lHfVqNQ8tLrQ4/m53lFhQ3D1ErMaaA" crossorigin="anonymous"></script>
</body>
</html>
