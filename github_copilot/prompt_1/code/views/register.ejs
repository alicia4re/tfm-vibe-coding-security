<%- include('partials/header', { title: 'Registro' }) %>
<div class="auth-card mx-auto">
  <h1 class="h3 mb-3">Crear cuenta</h1>
  <p class="text-muted">Regístrate con tu email y comienza a gestionar tareas.</p>
  <form action="/register" method="POST" class="mt-4">
    <div class="mb-3">
      <label class="form-label">Email</label>
      <input type="email" name="email" class="form-control" required />
    </div>
    <div class="mb-3">
      <label class="form-label">Contraseña</label>
      <input type="password" name="password" class="form-control" required />
    </div>
    <div class="mb-3">
      <label class="form-label">Confirmar contraseña</label>
      <input type="password" name="confirm" class="form-control" required />
    </div>
    <button class="btn btn-primary w-100">Registrarse</button>
  </form>
  <p class="text-center text-muted mt-3">¿Ya tienes cuenta? <a href="/login">Inicia sesión</a></p>
</div>
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-4XfIbwSvgIHm5MUo1GpT7qIuY4x+fzPCO5lHfVqNQ8tLrQ4/m53lFhQ3D1ErMaaA" crossorigin="anonymous"></script>
</body>
</html>
