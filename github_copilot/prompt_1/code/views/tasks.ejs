<%- include('partials/header', { title: 'Tareas' }) %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h4 mb-1">Tareas</h1>
    <p class="text-muted mb-0">Gestiona tus tareas y utiliza los filtros para encontrar lo que necesitas.</p>
  </div>
  <a href="/tasks/new" class="btn btn-primary">Nueva tarea</a>
</div>
<div class="card mb-4 p-3 bg-light shadow-sm">
  <form class="row g-3" method="GET" action="/tasks">
    <div class="col-md-4">
      <label class="form-label">Estado</label>
      <select name="status" class="form-select">
        <option value="">Todos</option>
        <option value="pendiente" <%= filters.status === 'pendiente' ? 'selected' : '' %>>Pendiente</option>
        <option value="en curso" <%= filters.status === 'en curso' ? 'selected' : '' %>>En curso</option>
        <option value="completada" <%= filters.status === 'completada' ? 'selected' : '' %>>Completada</option>
      </select>
    </div>
    <div class="col-md-4">
      <label class="form-label">Prioridad</label>
      <select name="priority" class="form-select">
        <option value="">Todas</option>
        <option value="baja" <%= filters.priority === 'baja' ? 'selected' : '' %>>Baja</option>
        <option value="media" <%= filters.priority === 'media' ? 'selected' : '' %>>Media</option>
        <option value="alta" <%= filters.priority === 'alta' ? 'selected' : '' %>>Alta</option>
      </select>
    </div>
    <div class="col-md-4">
      <label class="form-label">Buscar</label>
      <div class="input-group">
        <input type="text" name="q" value="<%= filters.q || '' %>" class="form-control" placeholder="Título o descripción" />
        <button class="btn btn-secondary">Filtrar</button>
      </div>
    </div>
  </form>
</div>
<div class="row gy-3">
  <% if (!tasks.length) { %>
    <div class="col-12">
      <div class="card p-4 text-center text-muted">No hay tareas para mostrar.</div>
    </div>
  <% } %>
  <% tasks.forEach(function(task) { %>
    <div class="col-12">
      <div class="card task-card shadow-sm">
        <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
          <div class="task-info">
            <div class="d-flex flex-column flex-md-row align-items-start gap-3 mb-2">
              <div>
                <span class="badge bg-<%= task.priority === 'alta' ? 'danger' : task.priority === 'media' ? 'warning text-dark' : 'secondary' %>"><%= task.priority.charAt(0).toUpperCase() + task.priority.slice(1) %></span>
                <span class="badge bg-<%= task.status === 'completada' ? 'success' : task.status === 'en curso' ? 'info text-dark' : 'secondary' %>"><%= stateLabel(task.status) %></span>
              </div>
              <h5 class="card-title mb-1"><%= task.title %></h5>
            </div>
            <p class="card-text text-muted"><%= task.description || 'Sin descripción' %></p>
            <div class="text-small text-muted">
              <span>Creada: <%= formatDate(task.created_at) %></span>
              <% if (task.due_date) { %> · <span>Fecha límite: <%= formatDate(task.due_date) %></span><% } %>
              <% if (currentUser.role === 'admin') { %> · <span>Usuario: <%= task.owner_email %></span><% } %>
            </div>
            <% if (task.attachment) { %>
              <div class="mt-2">
                <a href="<%= task.attachment %>" target="_blank" class="link-primary">Adjunto: <%= task.attachment_name %></a>
              </div>
            <% } %>
          </div>
          <div class="task-actions text-end">
            <a href="/tasks/<%= task.id %>/edit" class="btn btn-outline-primary btn-sm mb-2">Editar</a>
            <form action="/tasks/<%= task.id %>?_method=DELETE" method="POST" class="d-inline">
              <button class="btn btn-outline-danger btn-sm" type="submit" onclick="return confirm('Eliminar esta tarea?');">Eliminar</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-4XfIbwSvgIHm5MUo1GpT7qIuY4x+fzPCO5lHfVqNQ8tLrQ4/m53lFhQ3D1ErMaaA" crossorigin="anonymous"></script>
</body>
</html>
