<%- include('partials/header', { title: 'Recuperar contraseña' }) %>
<div class="auth-card mx-auto">
  <h1 class="h3 mb-3">Recuperar contraseña</h1>
  <p class="text-muted">Ingresa tu email y te enviaremos un enlace para restablecer tu contraseña.</p>
  <form action="/forgot" method="POST" class="mt-4">
    <div class="mb-3">
      <label class="form-label">Email</label>
      <input type="email" name="email" class="form-control" required />
    </div>
    <button class="btn btn-primary w-100">Enviar enlace</button>
  </form>
  <p class="text-center text-muted mt-3"><a href="/login">Volver al inicio de sesión</a></p>
</div>
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-4XfIbwSvgIHm5MUo1GpT7qIuY4x+fzPCO5lHfVqNQ8tLrQ4/m53lFhQ3D1ErMaaA" crossorigin="anonymous"></script>
</body>
</html>
