<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Gestor de Tareas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-c3Q5t0g2VOKGQp6DgSWmD0w0Yyh5NI9CRFm6C1x/9E3tZ3uv6VYao5x3MVB3p4h6" crossorigin="anonymous" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<header class="site-header shadow-sm">
  <nav class="navbar navbar-expand-lg navbar-light container py-3">
    <a class="navbar-brand fw-bold" href="/tasks">Gestor de Tareas</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto align-items-center">
        <% if (!currentUser) { %>
          <li class="nav-item"><a class="nav-link" href="/login">Iniciar sesión</a></li>
          <li class="nav-item"><a class="nav-link btn btn-primary text-white ms-2" href="/register">Registrarse</a></li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/tasks">Mis tareas</a></li>
          <% if (currentUser.role === 'admin') { %>
            <li class="nav-item"><a class="nav-link" href="/admin">Administrador</a></li>
          <% } %>
          <li class="nav-item dropdown ms-2">
            <a class="nav-link dropdown-toggle btn btn-outline-secondary" href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <%= currentUser.email %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
              <li><a class="dropdown-item" href="/tasks">Mis tareas</a></li>
              <li><hr class="dropdown-divider" /></li>
              <li>
                <form action="/logout" method="POST" class="m-0">
                  <button type="submit" class="dropdown-item">Cerrar sesión</button>
                </form>
              </li>
            </ul>
          </li>
        <% } %>
      </ul>
    </div>
  </nav>
</header>
<main class="container py-5">
  <%- include('./messages') %>
