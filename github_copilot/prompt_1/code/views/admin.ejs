<%- include('partials/header', { title: 'Panel administrador' }) %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h4 mb-1">Panel de administrador</h1>
    <p class="text-muted mb-0">Gestiona usuarios, roles y observa indicadores de actividad.</p>
  </div>
  <a href="/tasks" class="btn btn-outline-secondary">Volver a tareas</a>
</div>
<div class="row gy-4">
  <div class="col-12 col-xl-6">
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h6 mb-3">Usuarios registrados</h2>
        <div class="table-responsive">
          <table class="table align-middle mb-0">
            <thead>
              <tr>
                <th>Email</th>
                <th>Rol</th>
                <th>Estado</th>
                <th class="text-end">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(function(user) { %>
                <tr>
                  <td><%= user.email %></td>
                  <td>
                    <form action="/admin/users/<%= user.id %>/role" method="POST" class="d-flex gap-2 align-items-center">
                      <select name="role" class="form-select form-select-sm">
                        <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>Usuario</option>
                        <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Administrador</option>
                      </select>
                      <button class="btn btn-sm btn-primary">Guardar</button>
                    </form>
                  </td>
                  <td><span class="badge <%= user.active ? 'bg-success' : 'bg-secondary' %>"><%= user.active ? 'Activo' : 'Desactivado' %></span></td>
                  <td class="text-end">
                    <form action="/admin/users/<%= user.id %>/status" method="POST">
                      <button class="btn btn-sm <%= user.active ? 'btn-outline-danger' : 'btn-outline-success' %>"><%= user.active ? 'Desactivar' : 'Reactivar' %></button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-xl-6">
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <h2 class="h6 mb-3">Tareas por estado</h2>
        <% if (!taskStats.length) { %>
          <p class="text-muted">No hay datos aún.</p>
        <% } else { %>
          <ul class="list-group list-group-flush">
            <% taskStats.forEach(function(stat) { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= stateLabel(stat.status) %></span>
                <span class="badge bg-primary rounded-pill"><%= stat.count %></span>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>
    </div>
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h6 mb-3">Usuarios más activos</h2>
        <% if (!activeUsers.length) { %>
          <p class="text-muted">Aún no hay tareas registradas.</p>
        <% } else { %>
          <ul class="list-group list-group-flush">
            <% activeUsers.forEach(function(user) { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><%= user.email %></span>
                <span class="badge bg-secondary rounded-pill"><%= user.task_count %></span>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>
    </div>
  </div>
</div>
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-4XfIbwSvgIHm5MUo1GpT7qIuY4x+fzPCO5lHfVqNQ8tLrQ4/m53lFhQ3D1ErMaaA" crossorigin="anonymous"></script>
</body>
</html>
